export run() {
    fib_numbers: List = _fib_list(10)
    print_list(fib_numbers)
}

local _fib_list(n: number) List {
    fib_list: List = list()
    i: number = 0
    while i < n {
        list_number_append(fib_list, _fib(i))
        i = i + 1
    }
    return fib_list
}

local _fib(n: number) number {
    if n == 0 or n == 1 {
        return n
    }
    return _fib(n - 1) + _fib(n - 2)
}
